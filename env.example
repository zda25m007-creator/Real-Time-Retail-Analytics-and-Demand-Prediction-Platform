# ============================================================
# Z5008 Retail Analytics Platform - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# MinIO Object Storage
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=bigdata123

# JupyterLab
JUPYTER_TOKEN=bigdata

# Airflow
AIRFLOW_UID=50000
AIRFLOW_WWW_USER_USERNAME=admin
AIRFLOW_WWW_USER_PASSWORD=admin
AIRFLOW_SECRET_KEY=your-secret-key-here

# PostgreSQL (used by Airflow and MLflow)
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
AWS_ACCESS_KEY_ID=admin
AWS_SECRET_ACCESS_KEY=bigdata123

# Kafka
KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC=retail-txn-v2

# Spark
SPARK_MASTER=spark://spark-master:7077

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# Groq API (for NL Query Interface - Bonus)
# Get free key from https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here

# Ports
JUPYTER_PORT=8888
SPARK_UI_PORT=8083
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MLFLOW_PORT=5000
AIRFLOW_PORT=8090
GRAFANA_PORT=3002
PROMETHEUS_PORT=9090
API_PORT=3001
DASHBOARD_PORT=8050
NL_QUERY_PORT=8051
METRICS_PORT=8099
